{
    "name": "vertigis-workflow-oslo-equipment",
    "private": true,
    "version": "2.2.0",
    "description": "Custom VertiGIS Studio Workflow activities for Oslo VA equipment-code merging (ledning + kum)",
    "license": "MIT",
    "author": "",
    "type": "module",
    "scripts": {
        "build": "vertigis-workflow-sdk build",
